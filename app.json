{
  "expo": {
    "name": "FitTrack Pro",
    "slug": "fittrack-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#007AFF"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.dharmonjames.fittrackpro"
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#FFFFFF"
    },
    "androidNavigationBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FitTrack Pro to access your photos",
          "cameraPermission": "Allow FitTrack Pro to use your camera"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9d6e8b72-44fa-42be-a088-4048753eeb9f"
      }
    }
  }
}
